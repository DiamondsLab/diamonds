# Check for emergency bypass
if [ "$HUSKY_SKIP_HOOKS" = "1" ] || [ "$EMERGENCY_BYPASS" = "1" ]; then
  echo "🚨 SECURITY HOOKS BYPASSED - EMERGENCY MODE"
  echo "   Reason should be documented in emergency bypass log"
  exit 0
fi

# Start performance monitoring
yarn perf-monitor start pre-commit

# Run lint-staged with --no-stash for submodule compatibility
# Note: lint-staged may return non-zero exit codes in git submodules even when successful
# We check the output to determine actual success
npx lint-staged --allow-empty --no-stash --verbose 2>&1 | tee /tmp/lint-staged-output.log
LINT_STAGED_EXIT=$?

# Check if lint-staged actually failed (look for FAILED messages in output)
if grep -q "\[FAILED\]" /tmp/lint-staged-output.log; then
  echo "❌ lint-staged tasks failed"
  yarn perf-monitor end false
  exit 1
elif [ $LINT_STAGED_EXIT -ne 0 ]; then
  # Exit code is non-zero but no actual failures - this is a known git submodule issue
  echo "⚠️  lint-staged returned non-zero exit code but all tasks completed successfully"
  yarn perf-monitor end true
  exit 0
else
  yarn perf-monitor end true
  exit 0
fi
